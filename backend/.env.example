# Banco de dados (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# JWT
JWT_SECRET="seu_jwt_secret_forte_aqui"
JWT_EXPIRES_IN="7d"

# Cloudinary (upload de imagens)
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="seu_api_secret"

# Mercado Pago
MP_ACCESS_TOKEN="seu_access_token_producao"
MP_WEBHOOK_SECRET="seu_webhook_secret"

# URLs (preencher apos deploy)
FRONTEND_URL="https://www.atlantasports.com.br"
BACKEND_URL="https://atlantasports-production.up.railway.app"

# E-mail (Gmail com App Password)
EMAIL_USER="sualoja@gmail.com"
EMAIL_PASS="sua_app_password_gmail"
BACKUP_EMAIL="seubackup@gmail.com"  # Opcional: destino dos backups (padrão = EMAIL_USER)

# Porta (Railway define automaticamente)
PORT=3001
