generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  cart         Cart[]
  reviews      Review[]
  wishlist     Wishlist[]
  couponUsages CouponUsage[]
  returns      Return[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  image    String?
  products Product[]

  @@map("categories")
}

model Product {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String
  price        Float
  comparePrice Float?
  costPrice    Float?
  stock        Int      @default(0)
  images       String[]
  availability String   @default("pronta_entrega")
  keywords     String?
  active       Boolean  @default(true)

  allowPersonalization         Boolean @default(false)
  personalizationPrice         Float   @default(0)
  personalizationNameEnabled   Boolean @default(false)
  personalizationNameMaxLength Int     @default(10)
  personalizationNumberEnabled   Boolean @default(false)
  personalizationNumberMaxDigits Int     @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]
  orderItems OrderItem[]
  cartItems  Cart[]
  reviews    Review[]
  wishlist   Wishlist[]
  variants   ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  size      String?
  color     String?
  stock     Int     @default(0)
  price     Float?
  active    Boolean @default(true)

  product    Product     @relation(fields: [productId], references: [id])
  cartItems  Cart[]
  orderItems OrderItem[]

  @@map("product_variants")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("wishlist")
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     Int?        @unique
  userId          String
  status          OrderStatus @default(PENDING)
  total           Float
  paymentId       String?
  paymentMethod   String?
  paymentStatus   String      @default("pending")
  shippingAddress Json
  shippingCost    Float       @default(0)
  trackingCode    String?
  adminNote       String?     @default("")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
  returns Return[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  variantId String?
  quantity  Int
  price     Float

  order       Order           @relation(fields: [orderId], references: [id])
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  returnItems ReturnItem[]

  @@map("order_items")
}

model Cart {
  id        String  @id @default(uuid())
  userId    String
  productId String
  variantId String?
  quantity  Int

  user    User            @relation(fields: [userId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("cart")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("reviews")
}

model Coupon {
  id         String    @id @default(uuid())
  code       String    @unique
  discount   Float
  type       String    @default("percentage")
  minValue   Float     @default(0)
  maxUses    Int?
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  active     Boolean   @default(true)
  onePerUser Boolean   @default(false)

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
  @@map("coupon_usages")
}

model BackupStatus {
  id               Int       @id @default(1)
  lastBackupAt     DateTime? @db.Timestamp(6)
  lastBackupStatus String?
  updatedAt        DateTime  @default(now()) @updatedAt @db.Timestamp(6)

  @@map("backup_status")
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  REFUNDED
  EXCHANGED
}

enum ReturnType {
  REFUND
  EXCHANGE
}

model Return {
  id           String       @id @default(uuid())
  returnNumber Int          @unique @default(autoincrement())
  orderId      String
  userId       String
  type         ReturnType   @default(REFUND)
  status       ReturnStatus @default(REQUESTED)
  reason       String
  adminNote    String?      @default("")
  refundAmount Float?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order Order        @relation(fields: [orderId], references: [id])
  user  User         @relation(fields: [userId], references: [id])
  items ReturnItem[]

  @@map("returns")
}

model ReturnItem {
  id          String @id @default(uuid())
  returnId    String
  orderItemId String
  quantity    Int

  return    Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("return_items")
}

model StoreConfig {
  id                   String    @id
  storeName            String?   @default("Atlanta Sports")
  storeSlogan          String?   @default("")
  banners              String[]  @default([])
  heroBadge            String?   @default("")
  heroTitle            String?   @default("")
  heroSubtitle         String?   @default("")
  heroBtnPrimary       String?   @default("")
  heroBtnPrimaryLink   String?   @default("")
  heroBtnSecondary     String?   @default("")
  heroBtnSecondaryLink String?   @default("")
  benefit1             String?   @default("")
  benefit2             String?   @default("")
  benefit3             String?   @default("")
  benefit4             String?   @default("")
  sectionCategories    String?   @default("")
  sectionFeatured      String?   @default("")
  freeShippingThreshold Float?   @default(299)
  shippingZones        Json?     @default("[]")
  pixDiscount          Float?    @default(0)
  pixKey               String?   @default("")
  pixHolder            String?   @default("")
  pixMessage           String?   @default("")
  parceladoMessage     String?   @default("")
  whatsapp             String?   @default("")
  footerEmail          String?   @default("")
  footerHours          String?   @default("")
  footerDesc           String?   @default("")
  footerLinks          Json?     @default("[]")
  termsContent         String?   @default("")
  installments         Json?
  updatedAt            DateTime? @default(now()) @db.Timestamp(6)

  @@map("store_config")
}
